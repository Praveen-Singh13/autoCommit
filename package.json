{
  "name": "auto-commit13",
  "displayName": "Auto-Commit!",
  "description": "Automatically commits your code whenever you close VS Code window with a clean and professional message generated and humanised by AI",
  "version": "0.0.2",
  "publisher": "PraveenSingh13",
  "repository": {
    "type": "git",
    "url": "https://github.com/Praveen-Singh13/autoCommit.git"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autocommit.triggerCommit",
        "title": "AutoCommit: Generate & Commit"
      }
    ],
    "configuration": {
      "title": "AutoCommit",
      "properties": {
        "autocommit.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the AI provider (Gemini / OpenAI). Leave empty to use config/config.json.",
          "order": 1
        },
        "autocommit.apiProvider": {
          "type": "string",
          "enum": [
            "gemini",
            "openai"
          ],
          "default": "gemini",
          "description": "AI API provider to use for generating commit messages.",
          "order": 2
        },
        "autocommit.model": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "Model name to use (e.g. gemini-2.0-flash, gpt-4o-mini).",
          "order": 3
        },
        "autocommit.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python executable.",
          "order": 4
        },
        "autocommit.commitOnClose": {
          "type": "boolean",
          "default": true,
          "description": "Automatically commit changes when VS Code window closes.",
          "order": 5
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  }
}
